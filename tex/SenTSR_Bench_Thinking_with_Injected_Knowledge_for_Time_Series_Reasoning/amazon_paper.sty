%%% Amazon-Branded Paper Style
%%%% Adapted from COLM 2024 Conference Style
%%%% Modified for Amazon AWS AI Labs branding

% Font encoding - T1 for proper character support
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% Palatino font
\RequirePackage{tgpagella} % text only
\RequirePackage{mathpazo}  % math & text
\RequirePackage{inconsolata} % for tt font

\RequirePackage{eso-pic} % used by \AddToShipoutPicture
\RequirePackage{fancyhdr}
\RequirePackage{xcolor}
\RequirePackage{natbib}
\RequirePackage[a4paper,margin=2.5cm,headheight=24pt]{geometry}
\RequirePackage{graphicx}
\RequirePackage[most]{tcolorbox}

% Datetime formatting
\RequirePackage[style=iso]{datetime2}
\RequirePackage{tikz}
\RequirePackage{titling}

\RequirePackage{microtype}
\RequirePackage{setspace}
\RequirePackage{hyperref}
\RequirePackage{url}

% Amazon Dark Blue color scheme
\definecolor{amazondarkblue}{RGB}{35,47,62}
\definecolor{amazondarkorange}{RGB}{255,153,0}
\definecolor{darkblue}{rgb}{0, 0, 0.5}

\hypersetup{colorlinks=true, citecolor=amazondarkblue, linkcolor=amazondarkblue, urlcolor=amazondarkblue}

% modification to natbib citations
\setcitestyle{authoryear,round,citesep={;},aysep={,},yysep={;}}

\renewcommand{\topfraction}{0.95}   % let figure take up nearly whole page
\renewcommand{\textfraction}{0.05}  % let figure take up nearly whole page

% We're never going to need a table of contents, so just flush it to
% save space --- suggested by drstrip@sandia-2
\def\addcontentsline#1#2#3{}

% Title stuff, taken from deproc.
\def\maketitle{\par
\begingroup
   \def\thefootnote{\fnsymbol{footnote}}
   \def\@makefnmark{\hbox to 0pt{$^{\@thefnmark}$\hss}} % for perfect author
                                                        % name centering
%   The footnote-mark was overlapping the footnote-text,
%   added the following to fix this problem               (MK)
   \long\def\@makefntext##1{\parindent 1em\noindent
                            \hbox to1.8em{\hss $\m@th ^{\@thefnmark}$}##1}
   \@maketitle \@thanks
\endgroup
\setcounter{footnote}{0}
\let\maketitle\relax \let\@maketitle\relax
\gdef\@thanks{}\gdef\@author{}\gdef\@title{}\let\thanks\relax}

% Header setup with Amazon logo
\usepackage{fancyhdr}
\pagestyle{fancy}

\fancyhead{}
\renewcommand{\headrulewidth}{1pt}
\renewcommand{\headrule}{{\color[HTML]{232F3E}\hrule\@height\headrulewidth\@width\headwidth\vskip-\headrulewidth}}

\fancypagestyle{firstpage}{
  \lhead{\includegraphics[height=15pt]{figures/amazon_logo.png}}
  \rhead{\raisebox{3pt}{\textcolor[HTML]{232F3E}{\textbf{SenTSR-Bench}}}}
  \renewcommand{\headrule}{{\color[HTML]{232F3E}\hrule\@height\headrulewidth\@width\headwidth\vskip-\headrulewidth}}
}

% Inline logo command for affiliations
\newcommand{\amazonlogo}{\raisebox{-2pt}{\includegraphics[height=1em]{figures/logo_new.png}}}

% GitHub and project links
\def\github{\raisebox{-1.5pt}{\includegraphics[height=1.05em]{logo/github-logo.pdf}}}
\def\project{\raisebox{-1.5pt}{\includegraphics[height=1.05em]{logo/link.png}}}

% Title (includes both anonimized and non-anonimized versions)
\def\@maketitle{\vbox{\hsize\textwidth
%\linewidth\hsize \vskip 0.1in \toptitlebar \centering
 {\centering {\Large\bf \@title\par}}
\vspace{-0.3cm}
%\bottomtitlebar % \vskip 0.1in %  minus
 \begin{quote}\rule{\z@}{6pt} {\centering\par{\@author}\par}\end{quote}%
\vskip 0.3in minus 0.1in
}%
\thispagestyle{firstpage}}

% Abstract environment with Amazon branding
\renewenvironment{abstract}
  {\begin{center}
    \begin{tcolorbox}[
        colframe=amazondarkblue,  % Border: Amazon Dark Blue
        colback=white,            % Background: white
        arc=2mm,                  % Rounded corners
        boxrule=0.9pt,            % Border thickness
        left=2mm, right=2mm,      % Horizontal padding
        top=3mm, bottom=3mm,      % Vertical padding
        enhanced,
        width=0.95\textwidth      % 95% width for centering
      ]
      \centering{\large\bf\color{amazondarkblue} Abstract}\par\vspace{1ex}
      \begin{quote}
  }
  {\end{quote}
    \end{tcolorbox}
  \end{center}
}

% Section: 13pt, sans-serif, bold, Amazon Dark Blue
\def\section{%
  \@startsection
    {section}{1}{\z@}%
    {-2.0ex plus -0.5ex minus -.2ex}%
    {1.5ex plus 0.3ex minus 0.2ex}%
    {\fontsize{13}{10}\selectfont\sffamily\bfseries\raggedright\color{amazondarkblue}}%
}

% Subsection: 11pt, sans-serif, bold, Amazon Dark Blue
\def\subsection{%
  \@startsection
    {subsection}{2}{\z@}%
    {-1.8ex plus -0.5ex minus -.2ex}%
    {0.8ex plus .2ex}%
    {\fontsize{11}{10}\selectfont\sffamily\bfseries\raggedright\color{amazondarkblue}}%
}

\def\subsubsection{\@startsection{subsubsection}{3}{\z@}{-1.5ex
plus      -0.5ex minus -.2ex}{0.5ex plus
.2ex}{\normalsize\bf\raggedright\color{amazondarkblue}}}
\def\paragraph{\@startsection{paragraph}{4}{\z@}{1.5ex plus
0.5ex minus .2ex}{-1em}{\normalsize\bf}}
\def\subparagraph{\@startsection{subparagraph}{5}{\z@}{1.5ex plus
  0.5ex minus .2ex}{-1em}{\normalsize}}
\def\subsubsubsection{\vskip
5pt{\noindent\normalsize\rm\raggedright}}


% Footnotes
\footnotesep 6.65pt %
\skip\footins 9pt plus 4pt minus 2pt
\def\footnoterule{\kern-3pt \hrule width 12pc \kern 2.6pt }
\setcounter{footnote}{0}

% Lists and paragraphs
\parindent 0pt
\topsep 4pt plus 1pt minus 2pt
\partopsep 1pt plus 0.5pt minus 0.5pt
\itemsep 2pt plus 1pt minus 0.5pt
\parsep 2pt plus 1pt minus 0.5pt
\parskip .5pc


%\leftmargin2em
\leftmargin3pc
\leftmargini\leftmargin \leftmarginii 2em
\leftmarginiii 1.5em \leftmarginiv 1.0em \leftmarginv .5em

%\labelsep \labelsep 5pt

\def\@listi{\leftmargin\leftmargini}
\def\@listii{\leftmargin\leftmarginii
   \labelwidth\leftmarginii\advance\labelwidth-\labelsep
   \topsep 2pt plus 1pt minus 0.5pt
   \parsep 1pt plus 0.5pt minus 0.5pt
   \itemsep \parsep}
\def\@listiii{\leftmargin\leftmarginiii
    \labelwidth\leftmarginiii\advance\labelwidth-\labelsep
    \topsep 1pt plus 0.5pt minus 0.5pt
    \parsep \z@ \partopsep 0.5pt plus 0pt minus 0.5pt
    \itemsep \topsep}
\def\@listiv{\leftmargin\leftmarginiv
     \labelwidth\leftmarginiv\advance\labelwidth-\labelsep}
\def\@listv{\leftmargin\leftmarginv
     \labelwidth\leftmarginv\advance\labelwidth-\labelsep}
\def\@listvi{\leftmargin\leftmarginvi
     \labelwidth\leftmarginvi\advance\labelwidth-\labelsep}

\abovedisplayskip 7pt plus2pt minus5pt%
\belowdisplayskip \abovedisplayskip
\abovedisplayshortskip  0pt plus3pt%
\belowdisplayshortskip  4pt plus3pt minus3pt%

% Less leading in most fonts (due to the narrow columns)
% The choices were between 1-pt and 1.5-pt leading
%\def\@normalsize{\@setsize\normalsize{11pt}\xpt\@xpt} % got rid of @ (MK)
\def\normalsize{\@setsize\normalsize{14pt}\xpt\@xpt}
\def\small{\@setsize\small{10pt}\ixpt\@ixpt}
\def\footnotesize{\@setsize\footnotesize{10pt}\ixpt\@ixpt}
\def\xsmall{\@setsize\xsmall{8.8pt}\viipt\@viipt}
\def\scriptsize{\@setsize\scriptsize{8pt}\viipt\@viipt}
\def\tiny{\@setsize\tiny{7pt}\vipt\@vipt}
\def\large{\@setsize\large{14pt}\xiipt\@xiipt}
\def\Large{\@setsize\Large{16pt}\xivpt\@xivpt}
\def\LARGE{\@setsize\LARGE{20pt}\xviipt\@xviipt}
\def\huge{\@setsize\huge{23pt}\xxpt\@xxpt}
\def\Huge{\@setsize\Huge{28pt}\xxvpt\@xxvpt}

\def\toptitlebar{\hrule height4pt\vskip .25in\vskip-\parskip}

\def\bottomtitlebar{\vskip .29in\vskip-\parskip\hrule height1pt\vskip
.09in} %
%Reduced second vskip to compensate for adding the strut in \@author
